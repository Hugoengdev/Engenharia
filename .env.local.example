NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (opcional): chave service_role — só para POST /api/admin/transfer-projects.
# Cadastro não precisa disto: confirmação de e-mail é feita no banco (migration 0006).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Token exigido no campo "Token de cadastro" ao criar conta (padrão: manager).
SIGNUP_INVITE_TOKEN=manager

# Uso único: transferir todos os projetos para o e-mail abaixo (header x-transfer-secret).
PROJECT_TRANSFER_SECRET=um-segredo-longo-aleatorio
TRANSFER_TARGET_EMAIL=hugogabrielsalles97@gmail.com

# GitHub Releases — storage para arquivos IFC. Exige um repositório privado
# e um fine-grained PAT com "Contents: Read and write" restrito a esse repo.
GITHUB_OWNER=your-github-username
GITHUB_REPO=bim4d-storage
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
