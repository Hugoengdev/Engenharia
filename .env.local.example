NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Releases — storage para arquivos IFC. Exige um repositório privado
# e um fine-grained PAT com "Contents: Read and write" restrito a esse repo.
GITHUB_OWNER=your-github-username
GITHUB_REPO=bim4d-storage
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
